<% layout("/layouts/boilerplate.ejs") %>
<body>

    <form novalidate id="form" method="post" action="/login"> 
    
    
    <div class="flex justify-center items-start min-h-screen pt-10 px-6">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-lg p-8 w-full max-w-lg">

      <!-- Header -->
      <div class="flex items-center justify-center gap-3 mb-6">

        <div>
          <h2 class="flex justify-center items-center text-3xl mb-3 font-semibold text-gray-900">
            Login
          </h2>
          <p class="text-sm text-gray-500">
            Find your perfect stay.
          </p>
        </div>
      </div>


      <div class="mt-6 mb-2">
            <label for="username" class="block text-sm font-medium text-gray-700">Username</label>
            <div class="mt-2">
              <input id="username" type="text" name="username" placeholder="Enter Username" required 
                class="block w-full rounded-lg border border-gray-300 py-2.5 px-4 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent sm:text-sm" />
            </div>
      </div>

      <div class="mt-6 mb-2">
            <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
            <div class="mt-2">
              <input id="password" type="password" name="password" placeholder="Enter Password" required 
                class="block w-full rounded-lg border border-gray-300 py-2.5 px-4 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent sm:text-sm" />
            </div>
      </div>


        <!-- Submit -->
        <button type="submit" class="
                mt-4
                w-full
                bg-rose-500
                hover:bg-rose-600
                active:scale-95
                text-white
                font-semibold
                rounded-xl
                py-3
                transition-all
                duration-200
                shadow-md
                hover:shadow-lg
                ">
          Login
        </button>

        <div class="flex items-center justify-center mt-4 gap-3 mb-6">
          <p class="text-sm text-gray-500">
            Don't have an account?
            <a class="font-semibold underline text-rose-500 hover:text-rose-700" href="/signup">
              Sign Up
            </a>
          </p>
        
        </div>
        </div>



      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById("form");

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      
      let isValid = true;

      form.querySelectorAll("[required]").forEach(field => {
        if (!field.value.trim()) {
          showError(field);
          isValid = false;
        } else {
          clearError(field);
        }
      });

      if (isValid) {
        form.submit();
      }
    });

    function showError(field) {
      field.classList.add("ring-1", "ring-rose-500", "border-rose-500");
      field.classList.remove("border-gray-300");

      if (!field.nextElementSibling?.classList.contains("error-msg")) {
        const msg = document.createElement("p");
        msg.className = "error-msg text-rose-500 text-xs mt-1";
        msg.textContent = getErrorMessage(field);
        field.insertAdjacentElement("afterend", msg);
      }
    }

    function clearError(field) {
      field.classList.remove("ring-1", "ring-rose-500", "border-rose-500");
      field.classList.add("border-gray-300");

      if (field.nextElementSibling?.classList.contains("error-msg")) {
        field.nextElementSibling.remove();
      }
    }

    function getErrorMessage(field) {
      const messages = {
        "username"       : "Username is required",
        "password" : "Password is required",
        "email" : "Email is required",
      };
      return messages[field.name] || "This field is required";
    }

    form.querySelectorAll("[required]").forEach(field => {
      field.addEventListener("input", () => clearError(field));
    });
  </script>
</body>

