<% layout("/layouts/boilerplate.ejs") %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">

    <img
      class="w-full h-80 object-cover"
      src="<%= listing.image %>"
      alt="<%= listing.title %>"
    />

    <div class="p-6">
      <h1 class="text-2xl font-semibold text-gray-900 mb-2"><%= listing.title %></h1>

      <p class="text-xl font-semibold text-red-500 mb-4">
        ₹<%= listing.price.toLocaleString("en-IN") %>
      </p>

      <p class="text-gray-600 text-sm leading-relaxed mb-5">
        <%= listing.description %>
      </p>

      <hr class="border-t border-gray-100 mb-5" />

      <div class="grid grid-cols-2 gap-3 mb-6">
        <div class="bg-gray-50 rounded-xl px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-400 mb-1">Location</p>
          <p class="text-sm text-gray-800"><%= listing.location %></p>
        </div>
        <div class="bg-gray-50 rounded-xl px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-400 mb-1">Country</p>
          <p class="text-sm text-gray-800"><%= listing.country %></p>
        </div>
      </div>

      <div class="flex gap-3">
        <form method="get" action="/listings/<%= listing.id %>/update">
          <button
            type="submit"
            class="px-5 py-2 text-sm font-medium border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition"
          >
            Edit listing
          </button>
        </form>
        
        <form method="get" action="/listings/<%= listing.id %>/review">
          <button
            type="submit"
            class="px-5 py-2 text-sm font-medium border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition"
          >
            Add Review
          </button>
        </form>

        <form method="post" action="/listings/<%= listing.id %>/delete?_method=DELETE">
          <button
            type="submit"
            class="px-5 py-2 text-sm font-medium border border-red-300 rounded-lg text-red-600 hover:bg-red-50 transition"
          >
            Delete listing
          </button>
        </form>

        
      </div>
    </div>

  </div>
  

 <div class="mt-8 ml-2">
    <hr class="border-t border-gray-100 mb-5" />
    <h2 class="text-2xl font-semibold text-gray-900 mb-2 mt-8">All Reviews</h2>

    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <% if(listing.reviews.length === 0) { %>
        <p class="text-gray-500 p-4">No reviews yet.</p>
    <% } else { %>
        <% listing.reviews.forEach(review => { %>
            <div class="bg-gray-50 rounded-xl px-4 py-3 mt-4 w-80">
                <p class="text-l font-semibold text-gray-800 mb-3"><%= review.createdBy %></p>
                <p class="text-sm font-semibold text-gray-800"><%= review.comment %></p>
                <span class="text-xs text-gray-500">Rating: <%= review.rating %> / 5 &#x2605;</span>
                <form method="post" action="/listings/<%= listing.id %>/delete/<%= review.id %>?_method=DELETE">
                <button class="mt-4 text-red-500 hover:text-red-700 font-medium text-sm transition-colors duration-200">Delete</button>
                </form>
            </div>
        <% }) %>
    <% } %>
    
    
    
    </div>
</div>
</div>

